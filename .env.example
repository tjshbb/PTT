# --- Database ---
# Postgres with pgvector extension enabled.
DATABASE_URL="postgresql://user:password@localhost:5432/datespark?schema=public"

# --- Auth (NextAuth / Auth.js) ---
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with: openssl rand -base64 32"
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# --- Anthropic (idea generation + embeddings) ---
ANTHROPIC_API_KEY=""

# --- Google Maps Platform ---
GOOGLE_MAPS_API_KEY=""
# Client-side key for the background map (Maps JavaScript API). Exposed to the
# browser, so restrict it by HTTP referrer + API in the Google Cloud Console.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=""

# --- Ticketing / events ---
TICKETMASTER_API_KEY=""
EVENTBRITE_API_TOKEN=""

# --- Reservations ---
# Resy/OpenTable do NOT offer fully open public booking APIs.
# These are placeholders for partner access where granted; otherwise the app
# falls back to deep links + availability handoff. See src/lib/integrations.
RESY_API_KEY=""           # TODO: requires Resy partnership — verify before use
OPENTABLE_PARTNER_ID=""   # TODO: requires OpenTable partnership — verify before use

# --- Optional ---
YELP_API_KEY=""
WEATHER_API_KEY=""
